{
    "manifest_version": 3,
    "name": "RedirectX",
    "version": "1.0.0",
    "description": "Automatically bypass redirect links and remove tracking parameters.",
    "permissions": [
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "64": "icons/icon64.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "64": "icons/icon64.png",
            "128": "icons/icon128.png"
        }
    }
}